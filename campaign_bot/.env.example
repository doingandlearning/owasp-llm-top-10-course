# CampaignBot — lab configuration (copy to .env)

# stub = offline demo (default) | live = OpenAI-compatible API (Phase 2)
LLM_MODE=stub

# Show assembled prompt in UI and /api/debug/last-prompt
SHOW_PROMPT=true

# Bind address (use 127.0.0.1 only in labs)
HOST=127.0.0.1
PORT=8080

# Live LLM (unused when LLM_MODE=stub)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
