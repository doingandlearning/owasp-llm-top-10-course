# CampaignBot — lab configuration (copy to .env)
# Shared CRM: repo data/ (auto) or LAB_DATA_DIR=/path

# stub = offline predictable demos | live = real model (less predictable)
LLM_MODE=stub

# lab = naive system prompt (workshop default) | hardened = explicit guardrails
SYSTEM_PROMPT_STYLE=lab
LLM_TEMPERATURE=0.9

# Show assembled prompt in UI and /api/debug/last-prompt
SHOW_PROMPT=true

# Log prompt/response sizes to stderr when true
DEBUG=false

# Block live API calls even when LLM_MODE=live (classrooms without keys)
DISABLE_LIVE_LLM=false

# Bind address — 127.0.0.1 for local Python; Docker Compose sets HOST=0.0.0.0 automatically
HOST=127.0.0.1
PORT=8080

# --- Live LLM (required when LLM_MODE=live) ---
# Provider: openai (default) | anthropic (Claude Messages API)
LLM_PROVIDER=openai

# OpenAI-compatible (OpenAI, Azure, Ollama, etc.)
# OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic Claude (https://docs.anthropic.com/en/api/messages)
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# alias also works: claude-haiku-4-5
# ANTHROPIC_BASE_URL=https://api.anthropic.com

LLM_TIMEOUT_SECONDS=60

# Examples:
# Azure: OPENAI_BASE_URL=https://YOUR_RESOURCE.openai.azure.com/openai/deployments/YOUR_DEPLOYMENT
#        OPENAI_MODEL=your-deployment-name
# Ollama: OPENAI_BASE_URL=http://127.0.0.1:11434/v1  OPENAI_MODEL=llama3.2  OPENAI_API_KEY=ollama
