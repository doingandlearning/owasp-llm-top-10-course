# InsightAgent — lab configuration (copy to .env)
# Shared CRM: repo data/ (auto) or LAB_DATA_DIR=/path

# stub = offline predictable demos | live = real planner model
LLM_MODE=stub

# lab = naive system prompt (workshop default) | hardened = explicit guardrails
SYSTEM_PROMPT_STYLE=lab
LLM_TEMPERATURE=0.9

SHOW_PROMPT=true
DEBUG=false
DISABLE_LIVE_LLM=false

HOST=127.0.0.1
PORT=8081
MAX_TOOL_STEPS=5

# --- Live planner (required when LLM_MODE=live) ---
# Provider: openai (default) | anthropic (Claude Messages API)
LLM_PROVIDER=openai

# OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_BASE_URL=https://api.anthropic.com

LLM_TIMEOUT_SECONDS=60

# Ollama: OPENAI_BASE_URL=http://127.0.0.1:11434/v1  OPENAI_MODEL=llama3.2  OPENAI_API_KEY=ollama
